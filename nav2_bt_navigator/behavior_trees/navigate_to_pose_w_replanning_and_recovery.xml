<!--
  导航至目标点行为树 — 周期性重规划（1Hz）与多层恢复机制

  核心逻辑：
    1. 以流水线方式依次完成 选择器初始化 → 全局路径规划（1Hz重规划） → 路径跟踪
    2. 规划失败时清除代价地图重试，跟踪失败时清除局部代价地图重试
    3. 若整个流水线失败，进入外层恢复：依次尝试 清除代价地图 → 原地旋转 → 等待 → 后退
    4. 外层恢复最多重试 6 次，保证导航鲁棒性
-->
<root BTCPP_format="4" main_tree_to_execute="NavigateToPoseWReplanningAndRecovery">
  <BehaviorTree ID="NavigateToPoseWReplanningAndRecovery">

    <!-- 外层恢复节点：包裹整个导航流水线，失败时执行恢复子树，最多重试 6 次 -->
    <RecoveryNode number_of_retries="6" name="NavigateRecovery">

      <!-- 流水线序列：依次执行各阶段，前一阶段完成后才进入下一阶段 -->
      <PipelineSequence name="NavigateWithReplanning">

        <!-- 进度检查器选择器：运行时动态切换机器人是否卡住的检测算法 -->
        <ProgressCheckerSelector selected_progress_checker="{selected_progress_checker}" default_progress_checker="progress_checker" topic_name="progress_checker_selector"/>

        <!-- 目标检查器选择器：运行时动态切换"是否到达目标"的判定算法（如单点/多角度判定） -->
        <GoalCheckerSelector selected_goal_checker="{selected_goal_checker}" default_goal_checker="general_goal_checker" topic_name="goal_checker_selector"/>

        <!-- 路径处理器选择器：运行时动态切换路径预处理算法 -->
        <PathHandlerSelector selected_path_handler="{selected_path_handler}" default_path_handler="PathHandler" topic_name="path_handler_selector"/>

        <!-- 控制器选择器：运行时动态切换局部路径跟踪控制器（如 DWB/TEB/MPPI/RPP） -->
        <ControllerSelector selected_controller="{selected_controller}" default_controller="FollowPath" topic_name="controller_selector"/>

        <!-- 规划器选择器：运行时动态切换全局路径规划算法（如 NavFn/Smac2D/StarPlanner） -->
        <PlannerSelector selected_planner="{selected_planner}" default_planner="GridBased" topic_name="planner_selector"/>

        <!-- 频率控制器：限制子节点的执行频率为 1Hz，即每秒最多触发一次路径规划 -->
        <RateController hz="1.0">

          <!-- 规划阶段恢复节点：路径规划失败时清除全局代价地图重试 1 次 -->
          <RecoveryNode number_of_retries="1" name="ComputePathToPose">

            <!-- 选择器：优先检查是否需要重新规划，不需要则复用现有路径 -->
            <Fallback name="FallbackComputePathToPose">

              <!-- 响应式序列：每次 tick 都重新评估是否需要重新规划 -->
              <ReactiveSequence name="CheckIfNewPathNeeded">

                <!-- 目标未更新检查：目标被外部修改时返回 SUCCESS → 触发重新规划 -->
                <Inverter>
                  <GlobalUpdatedGoal/>
                </Inverter>

                <!-- 目标距离检查：机器人距离路径终点 < 4.0m 时认为接近目标，无需重规划 -->
                <IsGoalNearby path="{path}" proximity_threshold="4.0" max_robot_pose_search_dist="1.5"/>

                <!-- 路径局部截断：取机器人前方至路径终点的剩余路径（不限制前方距离，不保留后方） -->
                <TruncatePathLocal input_path="{path}" output_path="{remaining_path}" distance_forward="-1" distance_backward="0.0" />

                <!-- 路径有效性验证：检查截断后的路径是否仍然可行（无障碍物碰撞） -->
                <ValidatePath path="{remaining_path}"/>

              </ReactiveSequence>

              <!-- 全局路径规划：从起点到目标点计算一条可行路径，写入黑板 {path} -->
              <ComputePathToPose goal="{goal}" path="{path}" planner_id="{selected_planner}" error_code_id="{compute_path_error_code}" error_msg="{compute_path_error_msg}"/>

            </Fallback>

            <!-- 规划恢复动作：仅在路径规划失败时执行 -->
            <Sequence>
              <!-- 判断规划错误码是否可通过清除代价地图来恢复 -->
              <WouldAPlannerRecoveryHelp error_code="{compute_path_error_code}"/>
              <!-- 清除全局代价地图：移除所有已知的障碍物标记，为重规划扫清障碍 -->
              <ClearEntireCostmap name="ClearGlobalCostmap-Context" service_name="global_costmap/clear_entirely_global_costmap"/>
            </Sequence>

          </RecoveryNode>
        </RateController>

        <!-- 跟踪阶段恢复节点：路径跟踪失败时清除局部代价地图重试 1 次 -->
        <RecoveryNode number_of_retries="1" name="FollowPath">
          <!-- 局部路径跟踪：沿着 {path} 执行速度指令，控制器内置 2D 激光雷达绕障 -->
          <FollowPath path="{path}" controller_id="{selected_controller}" error_code_id="{follow_path_error_code}" error_msg="{follow_path_error_msg}" tracking_feedback="{tracking_feedback}"/>
          <!-- 跟踪恢复动作：仅在路径跟踪失败时执行 -->
          <Sequence>
            <!-- 判断控制器错误码是否可通过清除代价地图来恢复 -->
            <WouldAControllerRecoveryHelp error_code="{follow_path_error_code}"/>
            <!-- 清除局部代价地图：移除局部范围内的障碍物标记，帮助控制器脱困 -->
            <ClearEntireCostmap name="ClearLocalCostmap-Context" service_name="local_costmap/clear_entirely_local_costmap"/>
          </Sequence>
        </RecoveryNode>

      </PipelineSequence>

      <!-- 外层恢复子树：当整个导航流水线失败（6次内部恢复耗尽后）执行 -->
      <Sequence>
        <!-- 判断是控制器问题还是规划器问题，决定恢复策略 -->
        <Fallback>
          <WouldAControllerRecoveryHelp error_code="{follow_path_error_code}"/>
          <WouldAPlannerRecoveryHelp error_code="{compute_path_error_code}"/>
        </Fallback>

        <!-- 响应式恢复选择器：目标更新时立即中止恢复，否则依次尝试以下恢复动作 -->
        <ReactiveFallback name="RecoveryFallback">
          <!-- 目标更新检查：外部下发新目标时返回 SUCCESS → 中止恢复，重新开始导航 -->
          <GoalUpdated/>
          <!-- 轮转恢复：每轮尝试一个恢复动作，下一轮切换到下一个 -->
          <RoundRobin name="RecoveryActions">
            <!-- 第1轮：清除代价地图（局部+全局） -->
            <Sequence name="ClearingActions">
              <ClearEntireCostmap name="ClearLocalCostmap-Subtree" service_name="local_costmap/clear_entirely_local_costmap"/>
              <ClearEntireCostmap name="ClearGlobalCostmap-Subtree" service_name="global_costmap/clear_entirely_global_costmap"/>
            </Sequence>
            <!-- 第2轮：原地旋转 90°（1.57 rad），尝试脱离困境 -->
            <Spin spin_dist="1.57" error_code_id="{spin_error_code}" error_msg="{spin_error_msg}"/>
            <!-- 第3轮：原地等待 5 秒，等待动态障碍物移开 -->
            <Wait wait_duration="5.0" error_code_id="{wait_error_code}" error_msg="{wait_error_msg}"/>
            <!-- 第4轮：向后退 0.30m，速度 0.15 m/s，腾出空间 -->
            <BackUp backup_dist="0.30" backup_speed="0.15" error_code_id="{backup_error_code}" error_msg="{backup_error_msg}"/>
          </RoundRobin>
        </ReactiveFallback>
      </Sequence>

    </RecoveryNode>

  </BehaviorTree>
</root>
