<root BTCPP_format="4" main_tree_to_execute="导航至目标点_重规划与恢复">
  <BehaviorTree ID="导航至目标点_重规划与恢复">

    <!-- 外层恢复节点：包裹整个导航流水线，失败时执行恢复子树，最多重试 6 次 -->
    <RecoveryNode number_of_retries="6" name="导航恢复（最多6次）">

      <!-- 流水线序列：依次执行各阶段，前一阶段完成后才进入下一阶段 -->
      <PipelineSequence name="导航流水线">

        <!-- 进度检查器选择器：运行时动态切换机器人是否卡住的检测算法 -->
        <ProgressCheckerSelector selected_progress_checker="{selected_progress_checker}" default_progress_checker="progress_checker" topic_name="progress_checker_selector" name="进度检查器选择"/>

        <!-- 目标检查器选择器：运行时动态切换是否到达目标的判定算法 -->
        <GoalCheckerSelector selected_goal_checker="{selected_goal_checker}" default_goal_checker="general_goal_checker" topic_name="goal_checker_selector" name="目标检查器选择"/>

        <!-- 路径处理器选择器：运行时动态切换路径预处理算法 -->
        <PathHandlerSelector selected_path_handler="{selected_path_handler}" default_path_handler="PathHandler" topic_name="path_handler_selector" name="路径处理器选择"/>

        <!-- 控制器选择器：运行时动态切换局部路径跟踪控制器 -->
        <ControllerSelector selected_controller="{selected_controller}" default_controller="FollowPath" topic_name="controller_selector" name="控制器选择"/>

        <!-- 规划器选择器：运行时动态切换全局路径规划算法 -->
        <PlannerSelector selected_planner="{selected_planner}" default_planner="GridBased" topic_name="planner_selector" name="规划器选择"/>

        <!-- 频率控制器：限制子节点执行频率为 1Hz -->
        <RateController hz="1.0" name="1Hz频率控制">

          <!-- 规划阶段恢复节点：路径规划失败时清除全局代价地图重试 1 次 -->
          <RecoveryNode number_of_retries="1" name="路径规划恢复">

            <!-- 选择器：优先检查是否需要重新规划，不需要则复用现有路径 -->
            <Fallback name="是否需要重规划">

              <!-- 响应式序列：每次 tick 都重新评估是否需要重新规划 -->
              <ReactiveSequence name="检查是否需要新路径">

                <!-- 目标未更新检查：目标被外部修改时触发重新规划 -->
                <Inverter name="取反">
                  <GlobalUpdatedGoal name="全局目标已更新？"/>
                </Inverter>

                <!-- 目标距离检查：机器人距离路径终点 < 4.0m 时认为接近目标 -->
                <IsGoalNearby path="{path}" proximity_threshold="4.0" max_robot_pose_search_dist="1.5" name="目标是否在附近？"/>

                <!-- 路径局部截断：取机器人前方至路径终点的剩余路径 -->
                <TruncatePathLocal input_path="{path}" output_path="{remaining_path}" distance_forward="-1" distance_backward="0.0" name="截取剩余路径"/>

                <!-- 路径有效性验证：检查截断后的路径是否仍然可行 -->
                <ValidatePath path="{remaining_path}" name="验证路径有效性"/>

              </ReactiveSequence>

              <!-- 全局路径规划：从起点到目标点计算可行路径 -->
              <ComputePathToPose goal="{goal}" path="{path}" planner_id="{selected_planner}" error_code_id="{compute_path_error_code}" error_msg="{compute_path_error_msg}" name="计算全局路径"/>

            </Fallback>

            <!-- 规划恢复动作：仅在路径规划失败时执行 -->
            <Sequence name="规划恢复动作">
              <!-- 判断规划错误码是否可通过清除代价地图来恢复 -->
              <WouldAPlannerRecoveryHelp error_code="{compute_path_error_code}" name="清除代价地图能修复规划吗？"/>
              <!-- 清除全局代价地图 -->
              <ClearEntireCostmap name="清除全局代价地图" service_name="global_costmap/clear_entirely_global_costmap"/>
            </Sequence>

          </RecoveryNode>
        </RateController>

        <!-- 跟踪阶段恢复节点：路径跟踪失败时清除局部代价地图重试 1 次 -->
        <RecoveryNode number_of_retries="1" name="路径跟踪恢复">
          <!-- 局部路径跟踪：沿路径执行速度指令，内置 2D 激光雷达绕障 -->
          <FollowPath path="{path}" controller_id="{selected_controller}" error_code_id="{follow_path_error_code}" error_msg="{follow_path_error_msg}" tracking_feedback="{tracking_feedback}" name="跟踪路径"/>
          <!-- 跟踪恢复动作：仅在路径跟踪失败时执行 -->
          <Sequence name="跟踪恢复动作">
            <!-- 判断控制器错误码是否可通过清除代价地图来恢复 -->
            <WouldAControllerRecoveryHelp error_code="{follow_path_error_code}" name="清除代价地图能修复跟踪吗？"/>
            <!-- 清除局部代价地图 -->
            <ClearEntireCostmap name="清除局部代价地图" service_name="local_costmap/clear_entirely_local_costmap"/>
          </Sequence>
        </RecoveryNode>

      </PipelineSequence>

      <!-- 外层恢复子树：当整个导航流水线失败后执行 -->
      <Sequence name="外层恢复子树">
        <!-- 判断是控制器问题还是规划器问题 -->
        <Fallback name="判断问题来源">
          <WouldAControllerRecoveryHelp error_code="{follow_path_error_code}" name="控制器问题？"/>
          <WouldAPlannerRecoveryHelp error_code="{compute_path_error_code}" name="规划器问题？"/>
        </Fallback>

        <!-- 响应式恢复选择器：目标更新时立即中止恢复 -->
        <ReactiveFallback name="恢复选择器">
          <!-- 目标更新检查：外部下发新目标时中止恢复 -->
          <GoalUpdated name="目标已更新？"/>
          <!-- 轮转恢复：每轮尝试一个恢复动作 -->
          <RoundRobin name="轮转恢复动作">
            <!-- 第1轮：清除代价地图（局部+全局） -->
            <Sequence name="清除代价地图">
              <ClearEntireCostmap name="清除局部代价地图" service_name="local_costmap/clear_entirely_local_costmap"/>
              <ClearEntireCostmap name="清除全局代价地图" service_name="global_costmap/clear_entirely_global_costmap"/>
            </Sequence>
            <!-- 第2轮：原地旋转 90° -->
            <Spin spin_dist="1.57" error_code_id="{spin_error_code}" error_msg="{spin_error_msg}" name="原地旋转90°"/>
            <!-- 第3轮：原地等待 5 秒 -->
            <Wait wait_duration="5.0" error_code_id="{wait_error_code}" error_msg="{wait_error_msg}" name="等待5秒"/>
            <!-- 第4轮：向后退 0.30m -->
            <BackUp backup_dist="0.30" backup_speed="0.15" error_code_id="{backup_error_code}" error_msg="{backup_error_msg}" name="后退0.3米"/>
          </RoundRobin>
        </ReactiveFallback>
      </Sequence>

    </RecoveryNode>

  </BehaviorTree>
</root>
